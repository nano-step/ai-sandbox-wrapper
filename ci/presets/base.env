# ai-opencode:base — minimal published image preset
#
# Sourced by .github/workflows/build-image.yml to set INSTALL_* flags
# before invoking lib/install-base.sh and lib/install-opencode.sh.
#
# Adding a new flag? Read AGENTS.md → "Adding a New Tool > Kind B".
# Policy: ASK THE USER which preset(s) a new flag belongs to. Never
# silently add a flag to a preset.

# Enabled (built into base image)
INSTALL_SPEC_KIT=1
INSTALL_UX_UI_PROMAX=1
INSTALL_OPENSPEC=1
INSTALL_RTK=1
INSTALL_PUP=1
INSTALL_ACLI=1
INSTALL_GO=1
INSTALL_CHROME_DEVTOOLS_MCP=1
INSTALL_PLAYWRIGHT_MCP=1
INSTALL_PLAYWRIGHT_HOST=1

# Disabled (override defaults / skip from preset)
INSTALL_OD_HELPERS=0
INSTALL_PLAYWRIGHT=0
INSTALL_RUBY=0
