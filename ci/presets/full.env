# ai-opencode:full — full published image preset
#
# Superset of base.env: adds OD_HELPERS and standalone Playwright.
# Sourced by .github/workflows/build-image.yml to set INSTALL_* flags
# before invoking lib/install-base.sh and lib/install-opencode.sh.
#
# Adding a new flag? Read AGENTS.md → "Adding a New Tool > Kind B".
# Policy: ASK THE USER which preset(s) a new flag belongs to. Never
# silently add a flag to a preset.

# Enabled — same as base.env
INSTALL_SPEC_KIT=1
INSTALL_UX_UI_PROMAX=1
INSTALL_OPENSPEC=1
INSTALL_RTK=1
INSTALL_PUP=1
INSTALL_ACLI=1
INSTALL_GO=1
INSTALL_CHROME_DEVTOOLS_MCP=1
INSTALL_PLAYWRIGHT_MCP=1
INSTALL_PLAYWRIGHT_HOST=1

# Build optimization: layer on top of already-published :base instead of rebuilding from scratch
FROM_IMAGE_PRESET=base

# Enabled — extras vs base
INSTALL_OD_HELPERS=1
INSTALL_PLAYWRIGHT=1

# Disabled (kept off in full per maintainer decision)
INSTALL_RUBY=0
